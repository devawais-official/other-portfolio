# Email delivery for the contact form (see README.md for setup steps)
# Get a free API key at https://resend.com after signing up.
RESEND_API_KEY=

# Where contact form submissions are sent. Defaults to the email in
# lib/siteConfig.ts if not set.
CONTACT_TO_EMAIL=mughal963@gmail.com

# The "from" address Resend sends as. Use "onboarding@resend.dev" until
# you verify your own domain in the Resend dashboard, then switch to
# something like "contact@yourdomain.com".
CONTACT_FROM_EMAIL=onboarding@resend.dev
